### Example 3: Inventory and Rewards

Demonstrates `InventoryUpdateBuilder` for atomic multi-operation transactions, reusable utility classes, and a multi-service workflow combining Content, Stats, and Inventory APIs.

**Utility class:**
```csharp
public static class InventoryHelper
{
    public static async Task<long> GetBalanceSafe(IBeamableServices services, string currencyId)
    {
        try
        {
            return await services.Inventory.GetCurrency(currencyId);
        }
        catch (Exception ex)
        {
            BeamableLogger.LogError($"GetBalanceSafe failed for currency={currencyId}: {ex.Message}");
            return 0;
        }
    }

    public static async Task<bool> HasSufficientBalance(
        IBeamableServices services, string currencyId, long requiredAmount)
    {
        var balance = await GetBalanceSafe(services, currencyId);
        return balance >= requiredAmount;
    }

    public static InventoryUpdateBuilder BuildPurchase(
        string currencyId, long price, string itemContentId)
    {
        var spend = new InventoryUpdateBuilder().CurrencyChange(currencyId, -price);
        var grant = new InventoryUpdateBuilder().AddItem(itemContentId);
        return spend.Concat(grant);
    }

    public static InventoryUpdateBuilder BuildRewardBundle(
        Dictionary<string, long> currencyRewards, List<string> itemContentIds)
    {
        var builder = new InventoryUpdateBuilder();
        if (currencyRewards != null)
            foreach (var kvp in currencyRewards)
                builder.CurrencyChange(kvp.Key, kvp.Value);
        if (itemContentIds != null)
            foreach (var contentId in itemContentIds)
                builder.AddItem(contentId);
        return builder;
    }
}
```

**Atomic purchase — deducts currency and grants item in one transaction:**
```csharp
[ClientCallable]
public async Task<PurchaseResponse> PurchaseItem(
    string currencyId, long price, string itemContentId)
{
    if (string.IsNullOrWhiteSpace(currencyId) ||
        string.IsNullOrWhiteSpace(itemContentId) || price <= 0)
        return new PurchaseResponse
        { Success = false, Error = "Invalid input: currencyId, itemContentId, and positive price required." };

    if (!await InventoryHelper.HasSufficientBalance(Services, currencyId, price))
        return new PurchaseResponse
        { Success = false, Error = $"Insufficient balance for currency '{currencyId}'." };

    try
    {
        var builder = InventoryHelper.BuildPurchase(currencyId, price, itemContentId);
        await Services.Inventory.Update(builder);
        var remaining = await Services.Inventory.GetCurrency(currencyId);

        return new PurchaseResponse
        {
            Success = true,
            ItemContentId = itemContentId,
            RemainingBalance = remaining
        };
    }
    catch (Exception ex)
    {
        BeamableLogger.LogError($"PurchaseItem failed: {ex.Message}");
        return new PurchaseResponse { Success = false, Error = "Purchase failed. Please try again." };
    }
}
```

**Multi-service workflow — completes an objective using Content + Stats + Inventory:**
```csharp
[Serializable]
public class GrantRewardsResponse
{
    public bool Success { get; set; }
    public string Error { get; set; }
    public int XpGranted { get; set; }
    public int NewTotalXp { get; set; }
    public int CurrentLevel { get; set; }
    public bool DidLevelUp { get; set; }
    public int ItemsGranted { get; set; }
}

private const int XP_PER_LEVEL_BASE = 100;

[ClientCallable]
public async Task<GrantRewardsResponse> FinishObjective(string objectiveId)
{
    if (string.IsNullOrWhiteSpace(objectiveId))
        return new GrantRewardsResponse { Success = false, Error = "Objective ID is required." };

    try
    {
        // Step 1: Fetch objective content definition
        var objective = await Services.Content.GetContent<ObjectiveContent>(
            new ContentRef(typeof(ObjectiveContent), objectiveId));
        if (objective == null)
            return new GrantRewardsResponse
            { Success = false, Error = $"Objective '{objectiveId}' not found." };

        // Step 2: Read current player stats
        var stats = await Services.Stats.GetFilteredStats(
            StatsDomainType.Game, StatsAccessType.Public, Context.UserId,
            new[] { "currentXp", "currentLevel" });

        stats.TryGetValue("currentXp", out var xpStr);
        stats.TryGetValue("currentLevel", out var levelStr);
        int.TryParse(xpStr, out var currentXp);
        int.TryParse(levelStr, out var currentLevel);
        if (currentLevel < 1) currentLevel = 1;

        // Step 3: Calculate XP and level-up
        var xpGranted = objective.xpReward;
        var newXp = currentXp + xpGranted;
        var requiredForNextLevel = (currentLevel * (currentLevel + 1) / 2) * XP_PER_LEVEL_BASE;
        var didLevelUp = newXp >= requiredForNextLevel;
        if (didLevelUp) currentLevel++;

        // Step 4: Update player stats
        await Services.Stats.SetStats(
            StatsDomainType.Game, StatsAccessType.Public, Context.UserId,
            new Dictionary<string, string>
            {
                { "currentXp", newXp.ToString() },
                { "currentLevel", currentLevel.ToString() }
            });

        // Step 5: Grant item rewards atomically
        var itemContentIds = objective.itemRewards?.Select(r => r.Id).ToList()
            ?? new List<string>();
        if (itemContentIds.Count > 0)
        {
            var rewardBuilder = InventoryHelper.BuildRewardBundle(null, itemContentIds);
            await Services.Inventory.Update(rewardBuilder);
        }

        return new GrantRewardsResponse
        {
            Success = true, XpGranted = xpGranted, NewTotalXp = newXp,
            CurrentLevel = currentLevel, DidLevelUp = didLevelUp,
            ItemsGranted = itemContentIds.Count
        };
    }
    catch (Exception ex)
    {
        BeamableLogger.LogError($"FinishObjective failed: {ex.Message}");
        return new GrantRewardsResponse { Success = false, Error = "Failed to complete objective." };
    }
}
```

**Key patterns:** `InventoryUpdateBuilder.Concat()` to compose atomic transactions, `GetBalanceSafe` for defensive currency reads, multi-step workflows (Content → Stats → Inventory), `GetFilteredStats` for batch stat reads, reusable utility class to keep microservice methods focused.

