### Example 4: Discord Federated Authentication

Demonstrates `IFederatedLogin<T>` for external auth provider integration, realm config for secrets management, external HTTP API calls, player initialization with starting stats, and a WebSocket bot for real-time event handling.

**Federation identity:**
```csharp
[FederationId(Id)]
public class DiscordId : IFederationId
{
    public const string Id = "discord";
}
```

**Microservice with federated login:**
```csharp
[Microservice("SampleFour")]
public partial class SampleFour : Microservice, IFederatedLogin<DiscordId>
{
    public const string DiscordWhitelistedStatKey = "matchmaking_discord_whitelisted";

    // Register singleton services via ConfigureServices
    [ConfigureServices]
    public static void ConfigureDiscord(IServiceBuilder builder)
    {
        builder.Builder.AddSingleton<DiscordBot>();
    }

    // IFederatedLogin — validate external token, return provider user_id
    async Promise<FederatedAuthenticationResponse> IFederatedLogin<DiscordId>.Authenticate(
        string token, string challenge, string solution)
    {
        var discordUser = await DiscordRequests.GetDiscordUserFromToken(token);
        if (discordUser == null)
            throw new UnauthorizedAccessException("Invalid Discord Token");
        return new FederatedAuthenticationResponse { user_id = discordUser.id };
    }
}
```

**Token validation — external HTTP call to Discord API:**
```csharp
public static async Task<DiscordUser> GetDiscordUserFromToken(string token)
{
    using var httpClient = new HttpClient();
    httpClient.DefaultRequestHeaders.Add("Authorization", $"Bearer {token}");
    var response = await httpClient.GetAsync("https://discord.com/api/v10/users/@me");

    if (!response.IsSuccessStatusCode) return null;

    var asStr = await response.Content.ReadAsStringAsync();
    try { return JsonUtility.FromJson<DiscordUser>(asStr); }
    catch (Exception) { return null; }
}
```

**Player initialization — populate starting stats from Discord profile:**
```csharp
private async Task CreatePlayerDiscord(Account account,
    Dictionary<string, string> properties,
    Dictionary<string, string> outStartingStats,
    InventoryUpdateBuilder outStartingInventory)
{
    var associatedDiscordIdentity = account.external?
        .FirstOrDefault(e => e.providerNamespace == DiscordId.Id);
    if (associatedDiscordIdentity == null) return;

    // Read secrets from realm config (set in Portal under "discord_integration" namespace)
    var discordRealmConfig = await DiscordRequests.GetDiscordRealmConfig(Services.RealmConfig);
    if (string.IsNullOrWhiteSpace(discordRealmConfig.BotToken) ||
        string.IsNullOrWhiteSpace(discordRealmConfig.GuildId))
        return;

    // Fetch Discord profile via Guild Member API
    var discordGuildUser = await DiscordRequests.GetGuildUserById(
        discordRealmConfig.BotToken, discordRealmConfig.GuildId,
        associatedDiscordIdentity.userId);

    if (discordGuildUser?.user == null)
        throw new MicroserviceException(404, "INVALID_DISCORD_USER_ID",
            $"Failed to find Discord user. ExternalID={associatedDiscordIdentity.userId}");

    // Set public starting stats from Discord profile
    var discordUser = discordGuildUser.user;
    outStartingStats["player_name"] = !string.IsNullOrWhiteSpace(discordUser.global_name)
        ? discordUser.global_name : discordUser.username;
    outStartingStats["avatar"] = string.IsNullOrEmpty(discordUser.avatar)
        ? string.Empty
        : $"https://cdn.discordapp.com/avatars/{discordUser.id}/{discordUser.avatar}.png";

    // Set private stat: matchmaking whitelist based on Discord roles
    var gamerTag = account.gamerTags.First(gta => gta.projectId == Context.Pid).gamerTag;
    var isWhitelisted = discordGuildUser.roles != null &&
        discordGuildUser.roles.Intersect(discordRealmConfig.RoleIds).Any();

    await using var requestingUser = AssumeNewUser(gamerTag);
    await requestingUser.Services.Stats.SetStats(
        StatsDomainType.Game, StatsAccessType.Private, gamerTag,
        new() { { DiscordWhitelistedStatKey, $"{isWhitelisted}" } });
}
```

**Realm config access:**
```csharp
public static async Task<DiscordRealmConfig> GetDiscordRealmConfig(
    IMicroserviceRealmConfigService realmConfigService)
{
    var realmConfig = await realmConfigService.GetRealmConfigSettings();
    var ns = realmConfig.GetNamespace("discord_integration");
    return new DiscordRealmConfig
    {
        BotToken = ns.GetSetting("bot_token"),
        GuildId = ns.GetSetting("guild_id"),
        NotifyChannel = ulong.TryParse(ns.GetSetting("notify_channel"), out var v) ? v : 0,
        RoleIds = ns.GetSetting("matchmaking_roles_whitelist")?.Trim().Split(",").ToHashSet() ?? [],
    };
}

public class DiscordRealmConfig
{
    public string BotToken;
    public string GuildId;
    public ulong NotifyChannel;
    public HashSet<string> RoleIds;
}
```

**Real-time Discord bot (WebSocket) — reacts to role changes:**
```csharp
public class DiscordBot
{
    private readonly IMicroserviceRealmConfigService _beamableConfigService;
    private readonly IMicroserviceStatsApi _beamableStatsService;
    private readonly IMicroserviceNotificationsApi _notificationsApi;
    private readonly IBeamableRequester _beamableRequester;
    private readonly DiscordSocketClient _discordClient;

    public DiscordBot(IBeamableRequester requester,
        IMicroserviceRealmConfigService realmConfigService,
        IMicroserviceStatsApi statsService,
        IMicroserviceNotificationsApi notificationsApi)
    {
        _beamableRequester = requester;
        _beamableConfigService = realmConfigService;
        _beamableStatsService = statsService;
        _notificationsApi = notificationsApi;

        _discordClient = new DiscordSocketClient(new DiscordSocketConfig
        {
            AlwaysDownloadUsers = true,
            GatewayIntents = GatewayIntents.Guilds | GatewayIntents.GuildMembers,
        });

        _discordClient.GuildMemberUpdated += OnGuildMemberUpdated;
    }

    public async Task Connect()
    {
        var config = await DiscordRequests.GetDiscordRealmConfig(_beamableConfigService);
        if (string.IsNullOrEmpty(config.BotToken) || config.RoleIds.Count == 0) return;

        await _discordClient.LoginAsync(TokenType.Bot, config.BotToken);
        await _discordClient.StartAsync();
    }

    // When a guild member's roles change, update their Beamable matchmaking stat
    private async Task OnGuildMemberUpdated(
        Cacheable<SocketGuildUser, ulong> cachedUser, SocketGuildUser postUpdateUser)
    {
        if (!cachedUser.HasValue) return;
        if (cachedUser.Value.Roles.Count == postUpdateUser.Roles.Count) return;

        var config = await DiscordRequests.GetDiscordRealmConfig(_beamableConfigService);
        var hasAccess = postUpdateUser.Roles
            .Any(role => config.RoleIds.Contains(role.Id.ToString()));

        var discordUserId = cachedUser.Value.Id.ToString();
        var account = await DiscordRequests.GetBeamableAccountFromDiscordId(
            _beamableRequester, discordUserId);
        var gamerTag = account.gamerTags
            .FirstOrDefault(a => a.projectId == _beamableRequester.Pid);
        if (gamerTag == null) return;

        await _beamableStatsService.SetStats("game", "private", "player",
            gamerTag.gamerTag,
            new Dictionary<string, string>
            { { SampleFour.DiscordWhitelistedStatKey, hasAccess.ToString() } });
        await _notificationsApi.NotifyPlayer(gamerTag.gamerTag, hasAccess);
    }
}
```

**Key patterns:** `IFederatedLogin<T>` for external auth providers, `[FederationId]` to declare the identity type, `[ConfigureServices]` for DI registration, `AssumeNewUser(gamerTag)` for acting as another player, realm config namespaces for secrets, external HTTP calls with `HttpClient`, `MicroserviceException` for typed errors, WebSocket bot with DI-injected Beamable services for real-time cross-platform sync.

