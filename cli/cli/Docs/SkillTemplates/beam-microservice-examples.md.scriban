### Example 2: MongoDB Storage — Town Builder

Demonstrates `StorageDocument` usage, MongoDB filter builders, player data isolation, input validation, and capacity checks.

**Storage setup:**
```csharp
[StorageObject("StorageSample")]
public class StorageSample : MongoStorageObject { }

[Serializable]
public class TownResident : StorageDocument
{
    public long PlayerId { get; set; }
    public string RegionName { get; set; } = string.Empty;
    public string ResidentName { get; set; } = string.Empty;
    public string Role { get; set; } = string.Empty;

    public TownResidentData ToData() => new TownResidentData
    {
        PlayerId = PlayerId, RegionName = RegionName,
        ResidentName = ResidentName, Role = Role
    };
}
```

**Response models:**
```csharp
[Serializable]
public class TownResidentData
{
    public long PlayerId { get; set; }
    public string RegionName { get; set; }
    public string ResidentName { get; set; }
    public string Role { get; set; }
}

[Serializable]
public class AddResidentResponse
{
    public bool Success { get; set; }
    public string Error { get; set; }
    public TownResidentData Resident { get; set; }
}

[Serializable]
public class RemoveResidentResponse
{
    public bool Success { get; set; }
    public string Error { get; set; }
}
```

**Microservice:**
```csharp
public partial class SampleTwo : Microservice
{
    private const string TOWN_RESIDENTS_COLLECTION = "town_residents";
    private const int MaxResidentsPerRegion = 20;
    private static readonly HashSet<string> ValidRoles =
        new() { "farmer", "merchant", "guard", "builder", "healer" };

    [ClientCallable]
    public async Task<AddResidentResponse> AddResident(
        string regionName, string residentName, string role)
    {
        if (string.IsNullOrWhiteSpace(regionName) || string.IsNullOrWhiteSpace(residentName))
            return new AddResidentResponse
            { Success = false, Error = "Region name and resident name are required." };

        if (!ValidRoles.Contains(role))
            return new AddResidentResponse
            { Success = false, Error = $"Invalid role '{role}'. Valid: {string.Join(", ", ValidRoles)}." };

        var collection = await Storage
            .StorageSampleCollection<TownResident>(TOWN_RESIDENTS_COLLECTION);

        // Compound filter: scope to current player + region
        var regionFilter = Builders<TownResident>.Filter.Eq(x => x.PlayerId, Context.UserId)
            & Builders<TownResident>.Filter.Eq(x => x.RegionName, regionName);

        // Capacity check before insert
        var currentCount = await collection.CountDocumentsAsync(regionFilter);
        if (currentCount >= MaxResidentsPerRegion)
            return new AddResidentResponse
            { Success = false, Error = $"Region '{regionName}' is full ({MaxResidentsPerRegion} max)." };

        var resident = new TownResident
        {
            PlayerId = Context.UserId,
            RegionName = regionName,
            ResidentName = residentName,
            Role = role
        };

        await collection.InsertOneAsync(resident);
        return new AddResidentResponse { Success = true, Resident = resident.ToData() };
    }

    [ClientCallable]
    public async Task<List<TownResidentData>> GetResidents(string regionName)
    {
        var collection = await Storage
            .StorageSampleCollection<TownResident>(TOWN_RESIDENTS_COLLECTION);

        var filter = Builders<TownResident>.Filter.Eq(x => x.PlayerId, Context.UserId)
            & Builders<TownResident>.Filter.Eq(x => x.RegionName, regionName);

        var residents = await collection.Find(filter).ToListAsync();
        return residents.Select(r => r.ToData()).ToList();
    }

    [ClientCallable]
    public async Task<RemoveResidentResponse> RemoveResident(
        string regionName, string residentName)
    {
        if (string.IsNullOrWhiteSpace(regionName) || string.IsNullOrWhiteSpace(residentName))
            return new RemoveResidentResponse
            { Success = false, Error = "Region name and resident name are required." };

        var collection = await Storage
            .StorageSampleCollection<TownResident>(TOWN_RESIDENTS_COLLECTION);

        var filter = Builders<TownResident>.Filter.Eq(x => x.PlayerId, Context.UserId)
            & Builders<TownResident>.Filter.Eq(x => x.RegionName, regionName)
            & Builders<TownResident>.Filter.Eq(x => x.ResidentName, residentName);

        var result = await collection.DeleteOneAsync(filter);
        if (result.DeletedCount == 0)
            return new RemoveResidentResponse
            { Success = false, Error = $"Resident '{residentName}' not found in '{regionName}'." };

        return new RemoveResidentResponse { Success = true };
    }
}
```

**Key patterns:** `StorageDocument` for MongoDB documents, typed extension methods (`StorageSampleCollection<T>`), `Builders<T>.Filter.Eq()` with `&` for compound filters, `Context.UserId` for player isolation, capacity checks via `CountDocumentsAsync`, `ToData()` mapping to keep storage internals out of responses.

