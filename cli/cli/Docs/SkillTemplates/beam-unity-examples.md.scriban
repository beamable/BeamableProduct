### Accounts and Authentication

**Basic account operations:**
```csharp
using Beamable;
using Beamable.Common.Api.Auth;
using Beamable.Platform.SDK.Auth;
using Beamable.Player;
using System.Threading.Tasks;
using UnityEngine;

public class AccountsUsage : MonoBehaviour
{
    [ContextMenu("Get Account Info")]
    private async void GetAccountInfo()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.Accounts.Refresh();

        PlayerAccount account = ctx.Accounts.Current;
        Debug.Log($"[Accounts] GamerTag: {account.GamerTag}");
        Debug.Log($"[Accounts] Alias: {account.Alias}");
        Debug.Log($"[Accounts] Email: {account.Email}");
        Debug.Log($"[Accounts] HasEmail: {account.HasEmail}");
        Debug.Log($"[Accounts] DeviceIds: {string.Join(", ", account.DeviceIds)}");
    }

    [ContextMenu("Set Alias")]
    private async void SetAlias()
    {
        var ctx = await BeamContext.Default.Instance;
        var updated = await ctx.Accounts.SetAlias("SampleAlias");
        Debug.Log($"[Accounts] Alias updated to: {updated.Alias}");
    }

    [ContextMenu("Set Avatar")]
    private async void SetAvatar()
    {
        var ctx = await BeamContext.Default.Instance;
        var updated = await ctx.Accounts.SetAvatar("avatar_01");
        Debug.Log($"[Accounts] Avatar updated to: {updated.Avatar}");
    }

    [ContextMenu("Create New Account")]
    private async void CreateNewAccount()
    {
        var ctx = await BeamContext.Default.Instance;
        var newAccount = await ctx.Accounts.CreateNewAccount();
        Debug.Log($"[Accounts] New account created — GamerTag: {newAccount.GamerTag}");
        Debug.Log("[Accounts] Call newAccount.SwitchToAccount() to switch to it");
    }

    [ContextMenu("Check Email Availability")]
    private async void CheckEmailAvailability()
    {
        var ctx = await BeamContext.Default.Instance;
        var isAvailable = await ctx.Accounts.IsEmailAvailable("test@example.com");
        Debug.Log($"[Accounts] Email test@example.com available: {isAvailable}");
    }
}
```

**Third-party authentication pattern:**

All providers follow the same Beamable-side flow. The provider-specific SDK obtains a token, then these shared helpers handle the rest:

```csharp
// 1. Check if credentials are already linked to an account
var credentialStatus = await ctx.Api.AuthService.GetCredentialStatus(thirdParty, token);
var available = credentialStatus == CredentialUsageStatus.NEVER_USED;
var userHasCredentials = ctx.Api.User.HasThirdPartyAssociation(thirdParty);

// 2a. Fresh token, no existing association → attach to current account
await ctx.Accounts.AddThirdParty(thirdParty, token);

// 2b. Token already linked to another account → recover/switch
var op = await ctx.Accounts.RecoverAccountWithThirdParty(thirdParty, token);
await op.SwitchToAccount();

// 3. Remove association
await ctx.Accounts.RemoveThirdParty(thirdParty, token);
```

**Supported providers** (`AuthThirdParty` enum): `Facebook`, `FacebookLimited` (iOS 14+), `Google`, `Apple` (iOS, via `com.lupidan.apple-auth`), `GoogleGamesServices` (Android, via `com.google.play.games` + `BEAMABLE_GPGS` define symbol).

