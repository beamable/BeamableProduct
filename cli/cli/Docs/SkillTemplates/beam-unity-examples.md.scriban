### Content

```csharp
using Beamable;
using Beamable.Common;
using Beamable.Common.Content;
using Beamable.Common.Inventory;
using UnityEngine;

public class ContentUsage : MonoBehaviour
{
    [ContextMenu("Get Manifest")]
    private async void GetManifest()
    {
        var ctx = await BeamContext.Default.Instance;
        var manifest = await ctx.Content.GetManifest();

        Debug.Log($"[Content] Manifest loaded — {manifest.entries.Count} entries:");
        foreach (var entry in manifest.entries)
            Debug.Log($"  - {entry.contentId} (type: {entry.type})");
    }

    [ContextMenu("Resolve Objective Content")]
    private async void ResolveObjectiveContent()
    {
        var contentRef = new ContentRef<ObjectiveContent>("objective.tutorial_1");
        var objective = await contentRef.Resolve();

        if (objective != null)
            Debug.Log($"[Content] Resolved: {objective.objectiveName} — XP: {objective.xpReward}, Items: {objective.itemRewards?.Count ?? 0}");
        else
            Debug.LogWarning("[Content] Could not resolve objective.tutorial_1");
    }

    [ContextMenu("Get Currency Content")]
    private async void GetCurrencyContent()
    {
        var ctx = await BeamContext.Default.Instance;
        var content = await ctx.Content.GetContent<CurrencyContent>(new CurrencyRef("currency.coins"));

        if (content != null)
            Debug.Log($"[Content] Currency: {content.name} (id: {content.Id})");
        else
            Debug.LogWarning("[Content] Could not resolve currency.coins");
    }
}
```

**Key patterns:** `ctx.Content.GetManifest()` for all content entries, `new ContentRef<T>(id).Resolve()` for typed content resolution, `ctx.Content.GetContent<T>(ref)` for direct fetching.

