### Announcements

```csharp
using Beamable;
using System.Linq;
using UnityEngine;

public class AnnouncementsUsage : MonoBehaviour
{
    [ContextMenu("Get Announcements")]
    private async void GetAnnouncements()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.Announcements.OnReady;

        Debug.Log("[Announcements] Current announcements:");
        foreach (var announcement in ctx.Announcements)
            Debug.Log($"  - [{announcement.Channel}] {announcement.Title} (Read: {announcement.IsRead}, Claimed: {announcement.IsClaimed})");
    }

    [ContextMenu("Read First Announcement")]
    private async void ReadFirstAnnouncement()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.Announcements.OnReady;

        var first = ctx.Announcements.FirstOrDefault();
        if (first == null)
        {
            Debug.LogWarning("[Announcements] No announcements available");
            return;
        }

        await ctx.Announcements.Read(first);
        Debug.Log($"[Announcements] Marked as read: {first.Title}");
    }

    [ContextMenu("Claim First Announcement")]
    private async void ClaimFirstAnnouncement()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.Announcements.OnReady;

        var first = ctx.Announcements.FirstOrDefault();
        if (first == null)
        {
            Debug.LogWarning("[Announcements] No announcements available");
            return;
        }

        await ctx.Announcements.Claim(first);
        Debug.Log($"[Announcements] Claimed: {first.Title}");
    }
}
```

**Key patterns:** `await ctx.Announcements.OnReady` before reading, iterable collection with `Channel`, `Title`, `IsRead`, `IsClaimed`, lifecycle methods `Read()` and `Claim()`.

