### Leaderboards

```csharp
using Beamable;
using Beamable.Player;
using UnityEngine;

public class LeaderboardsUsage : MonoBehaviour
{
    [ContextMenu("Get Board")]
    private async void GetBoard()
    {
        var ctx = await BeamContext.Default.Instance;
        var board = ctx.Leaderboards.GetBoard("leaderboards.high_score");

        if (board == null)
        {
            Debug.LogError("[Leaderboards] Board not found: leaderboards.high_score");
            return;
        }
        var playerStanding = board.myStandings.HasValue ? board.myStandings.Value.score : 0;
        Debug.Log($"[Leaderboards] Board: {board.boardId}, Player Score: {playerStanding}");
        Debug.Log("[Leaderboards] Use board.OnUpdated to subscribe to score changes");
    }
}
```

**Key patterns:** `ctx.Leaderboards.GetBoard(id)` returns a board with `myStandings` (nullable), subscribe to `board.OnUpdated` for real-time changes.

