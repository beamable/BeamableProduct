## Calling Microservices from Unity

Shows how the Unity client calls `[ClientCallable]` endpoints via auto-generated client proxies.
Access pattern: `ctx.Microservices.{ServiceName}()` returns a typed client with `{ServiceName}_{MethodName}(args)` methods.

> **Note:** SampleOne through SampleFour here are the Unity client counterparts of the same microservices documented in the `beam-microservice-examples` skill. Load that skill to see the server-side implementation of each endpoint.

### Basic Service Calls

```csharp
using Beamable;
using Beamable.Common;
using Beamable.Server.Clients;
using UnityEngine;

public class SampleOneUsage : MonoBehaviour
{
    [ContextMenu("Health Check")]
    private async void HealthCheck()
    {
        var ctx = await BeamContext.Default.Instance;
        var client = ctx.Microservices.SampleOne();

        var result = await client.SampleOne_HealthCheck();
        Debug.Log($"[SampleOne] HealthCheck — Status: {result.Status}, Version: {result.Version}, Time: {result.Timestamp}");
    }

    [ContextMenu("Get My Score")]
    private async void GetMyScore()
    {
        var ctx = await BeamContext.Default.Instance;
        var client = ctx.Microservices.SampleOne();

        var result = await client.SampleOne_GetPlayerScore();
        Debug.Log($"[SampleOne] GetPlayerScore — Status: {result.Status}, Score: {result.Value}, PlayerId: {result.PlayerId}");
    }
}
```

---

### CRUD Operations (Storage-Backed)

```csharp
using Beamable;
using Beamable.Common;
using Beamable.Server.Clients;
using UnityEngine;

public class SampleTwoUsage : MonoBehaviour
{
    [ContextMenu("Add Resident")]
    private async void AddResident()
    {
        var ctx = await BeamContext.Default.Instance;
        var client = ctx.Microservices.SampleTwo();

        var result = await client.SampleTwo_AddResident("town_center", "Alice", "merchant");
        if (result.Success)
            Debug.Log($"[SampleTwo] Added: {result.Resident.ResidentName} ({result.Resident.Role}) in {result.Resident.RegionName}");
        else
            Debug.LogWarning($"[SampleTwo] AddResident failed: {result.Error}");
    }

    [ContextMenu("Get Residents")]
    private async void GetResidents()
    {
        var ctx = await BeamContext.Default.Instance;
        var client = ctx.Microservices.SampleTwo();

        var residents = await client.SampleTwo_GetResidents("town_center");
        Debug.Log($"[SampleTwo] Found {residents.Count} resident(s) in town_center:");
        foreach (var r in residents)
            Debug.Log($"  - {r.ResidentName} ({r.Role})");
    }

    [ContextMenu("Remove Resident")]
    private async void RemoveResident()
    {
        var ctx = await BeamContext.Default.Instance;
        var client = ctx.Microservices.SampleTwo();

        var result = await client.SampleTwo_RemoveResident("town_center", "Alice");
        if (result.Success)
            Debug.Log("[SampleTwo] Resident removed successfully");
        else
            Debug.LogWarning($"[SampleTwo] RemoveResident failed: {result.Error}");
    }
}
```

