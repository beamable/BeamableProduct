### Cloud Saving

```csharp
using Beamable;
using Beamable.Player.CloudSaving;
using UnityEngine;

public class CloudSavingUsage : MonoBehaviour
{
    [ContextMenu("Init Cloud Saving")]
    private async void InitCloudSaving()
    {
        var ctx = await BeamContext.Default.Instance;
        var status = await ctx.CloudSaving.Init();
        Debug.Log($"[CloudSaving] Initialized — Status: {status}");
    }

    [ContextMenu("Save Data")]
    private async void SaveData()
    {
        var ctx = await BeamContext.Default.Instance;
        if (ctx.CloudSaving.ServiceStatus != CloudSaveStatus.Initialized)
        {
            Debug.LogWarning("[CloudSaving] Service not initialized. Call Init first.");
            return;
        }

        var data = "{\"level\": 5, \"checkpoint\": \"forest_gate\"}";
        await ctx.CloudSaving.SaveData("sample_save.json", data);
        Debug.Log("[CloudSaving] Saved sample_save.json");
    }

    [ContextMenu("Load Data")]
    private async void LoadData()
    {
        var ctx = await BeamContext.Default.Instance;
        if (ctx.CloudSaving.ServiceStatus != CloudSaveStatus.Initialized)
        {
            Debug.LogWarning("[CloudSaving] Service not initialized. Call Init first.");
            return;
        }

        var content = await ctx.CloudSaving.LoadDataString("sample_save.json");
        if (content != null)
            Debug.Log($"[CloudSaving] Loaded: {content}");
        else
            Debug.LogWarning("[CloudSaving] No data found for sample_save.json");
    }

    [ContextMenu("Force Upload")]
    private async void ForceUpload()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.CloudSaving.ForceUploadLocalData();
        Debug.Log("[CloudSaving] Forced upload of local data");
    }

    [ContextMenu("Force Download")]
    private async void ForceDownload()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.CloudSaving.ForceDownloadCloudData();
        Debug.Log("[CloudSaving] Forced download of cloud data");
    }
}
```

**Key patterns:** `ctx.CloudSaving.Init()` must be called before save/load, check `ServiceStatus == CloudSaveStatus.Initialized`, `SaveData(fileName, jsonString)` / `LoadDataString(fileName)` for persistence, `ForceUploadLocalData()` / `ForceDownloadCloudData()` for manual sync.

