### Social

```csharp
using Beamable;
using Beamable.Player;
using UnityEngine;

public class SocialUsage : MonoBehaviour
{
    [ContextMenu("Get Friends")]
    private async void GetFriends()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.Social.OnReady;

        Debug.Log($"[Social] Friends ({ctx.Social.Friends.Count}):");
        foreach (PlayerFriend friend in ctx.Social.Friends)
            Debug.Log($"  - PlayerId: {friend.playerId}");
    }

    [ContextMenu("Get Received Invites")]
    private async void GetReceivedInvites()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.Social.OnReady;

        Debug.Log($"[Social] Received invites ({ctx.Social.ReceivedInvites.Count}):");
        foreach (ReceivedFriendInvite invite in ctx.Social.ReceivedInvites)
            Debug.Log($"  - From PlayerId: {invite.invitingPlayerId}");
    }

    [ContextMenu("Get Sent Invites")]
    private async void GetSentInvites()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.Social.OnReady;

        Debug.Log($"[Social] Sent invites ({ctx.Social.SentInvites.Count}):");
        foreach (SentFriendInvite invite in ctx.Social.SentInvites)
            Debug.Log($"  - To PlayerId: {invite.invitedPlayerId}");
    }

    [ContextMenu("Get Blocked Players")]
    private async void GetBlockedPlayers()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.Social.OnReady;

        Debug.Log($"[Social] Blocked ({ctx.Social.Blocked.Count}):");
        foreach (BlockedPlayer blocked in ctx.Social.Blocked)
            Debug.Log($"  - PlayerId: {blocked.playerId}");
    }

    [ContextMenu("Invite Friend (id: 12345)")]
    private async void InviteFriend()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.Social.Invite(12345).Error(e =>
        {
            Debug.LogWarning($"[Social] Failed to invite: {e.Message}");
        });
        Debug.Log("[Social] Invite sent to PlayerId 12345");
    }

    [ContextMenu("Refresh Social")]
    private async void RefreshSocial()
    {
        var ctx = await BeamContext.Default.Instance;
        await ctx.Social.Refresh();
        Debug.Log($"[Social] Refreshed — {ctx.Social.Friends.Count} friend(s), {ctx.Social.Blocked.Count} blocked");
    }
}
```

**Key patterns:** `await ctx.Social.OnReady`, collections for `Friends`, `ReceivedInvites`, `SentInvites`, `Blocked`, action methods `Invite(playerId)` and `Refresh()`, `.Error()` callback for error handling.

