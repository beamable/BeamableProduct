### Economy and Objectives

```csharp
using Beamable;
using Beamable.Common;
using Beamable.Server.Clients;
using UnityEngine;

public class SampleThreeUsage : MonoBehaviour
{
    [ContextMenu("Get Balance")]
    private async void GetBalance()
    {
        var ctx = await BeamContext.Default.Instance;
        var client = ctx.Microservices.SampleThree();

        var result = await client.SampleThree_GetBalance("currency.coins");
        Debug.Log($"[SampleThree] Balance — Status: {result.Status}, Currency: {result.CurrencyId}, Amount: {result.Balance}");
    }

    [ContextMenu("Add Currency (+500)")]
    private async void AddCurrency()
    {
        var ctx = await BeamContext.Default.Instance;
        var client = ctx.Microservices.SampleThree();

        var result = await client.SampleThree_UpdateCurrency("currency.coins", 500);
        Debug.Log($"[SampleThree] UpdateCurrency — Status: {result.Status}, New Balance: {result.Balance}");
    }

    [ContextMenu("Purchase Item")]
    private async void PurchaseItem()
    {
        var ctx = await BeamContext.Default.Instance;
        var client = ctx.Microservices.SampleThree();

        var result = await client.SampleThree_PurchaseItem("currency.coins", 100, "items.sword");
        if (result.Success)
            Debug.Log($"[SampleThree] Purchased {result.ItemContentId}, Remaining: {result.RemainingBalance}");
        else
            Debug.LogWarning($"[SampleThree] Purchase failed: {result.Error}");
    }

    [ContextMenu("Finish Objective")]
    private async void FinishObjective()
    {
        var ctx = await BeamContext.Default.Instance;
        var client = ctx.Microservices.SampleThree();

        var result = await client.SampleThree_FinishObjective("objective.tutorial_1");
        if (result.Success)
            Debug.Log($"[SampleThree] Objective complete — XP: +{result.XpGranted} (Total: {result.NewTotalXp}), Level: {result.CurrentLevel}, LevelUp: {result.DidLevelUp}, Items: {result.ItemsGranted}");
        else
            Debug.LogWarning($"[SampleThree] FinishObjective failed: {result.Error}");
    }
}
```

