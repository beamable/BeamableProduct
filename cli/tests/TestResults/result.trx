#include "BeamableCore/Public/AutoGen/TroublesomeAddResponseLibrary.h"&#xD;
&#xD;
#include "CoreMinimal.h"&#xD;
#include "BeamCoreSettings.h"&#xD;
&#xD;
&#xD;
FString UTroublesomeAddResponseLibrary::TroublesomeAddResponseToJsonString(const UTroublesomeAddResponse* Serializable, const bool Pretty)&#xD;
{&#xD;
	FString Result = FString{};&#xD;
	if(Pretty)&#xD;
	{&#xD;
		TUnrealPrettyJsonSerializer JsonSerializer = TJsonStringWriter&lt;TPrettyJsonPrintPolicy&lt;TCHAR&gt;&gt;::Create(&amp;Result);&#xD;
		Serializable-&gt;BeamSerialize(JsonSerializer);&#xD;
		JsonSerializer-&gt;Close();&#xD;
	}&#xD;
	else&#xD;
	{&#xD;
		TUnrealJsonSerializer JsonSerializer = TJsonStringWriter&lt;TCondensedJsonPrintPolicy&lt;TCHAR&gt;&gt;::Create(&amp;Result);&#xD;
		Serializable-&gt;BeamSerialize(JsonSerializer);&#xD;
		JsonSerializer-&gt;Close();			&#xD;
	}&#xD;
	return Result;&#xD;
}	&#xD;
&#xD;
UTroublesomeAddResponse* UTroublesomeAddResponseLibrary::Make(int32 Value, UObject* Outer)&#xD;
{&#xD;
	auto Serializable = NewObject&lt;UTroublesomeAddResponse&gt;(Outer);&#xD;
	Serializable-&gt;Value = Value;&#xD;
	&#xD;
	return Serializable;&#xD;
}&#xD;
&#xD;
void UTroublesomeAddResponseLibrary::Break(const UTroublesomeAddResponse* Serializable, int32&amp; Value)&#xD;
{&#xD;
	if(GetDefault&lt;UBeamCoreSettings&gt;()-&gt;BreakGuard(Serializable))&#xD;
	{&#xD;
		Value = Serializable-&gt;Value;&#xD;
	}&#xD;
		&#xD;
}&#xD;
