  # Expo SDK 56 pins react@19.2.3 (for React Native), but react-dom only publishes
# 19.2.7 (which peer-requires react@^19.2.7). react-dom is pulled in transitively by
# expo-router's web preview deps (@radix-ui/*, vaul) and is never loaded on a device,
# so this peer mismatch is harmless. legacy-peer-deps lets `npm install` resolve the
# tree instead of hard-failing with ERESOLVE.
legacy-peer-deps=true
