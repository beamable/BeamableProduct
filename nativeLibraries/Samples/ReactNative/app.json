{
  "expo": {
    "name": "Beam RN Sample",
    "slug": "beam-rn-sample",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "beamrnsample",
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "ios": {
      "bundleIdentifier": "com.beamble.samples.beamfarmrn",
      "supportsTablet": true
    },
    "android": {
      "package": "com.beamable.rnsample",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-asset",
      [
        "@beamable/notifications-react-native",
        {
          "appGroup": "group.com.beamable.mobiletest",
          "enableServiceExtension": true
        }
      ],
      "./plugins/withSampleNotificationStyles"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
