{
  "expo": {
    "name": "Beam RN Sample",
    "slug": "beam-rn-sample",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "beamrnsample",
    "ios": {
      "bundleIdentifier": "com.beamble.samples.beamfarmrn",
      "supportsTablet": true
    },
    "android": {
      "package": "com.beamable.rnsample",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.24",
            "newArchEnabled": false
          }
        }
      ],
      [
        "./plugins/withBeamableNotifications",
        {
          "appGroup": "group.com.beamable.mobiletest",
          "enableServiceExtension": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
