{
  "name": "beam-rn-sample",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild --clean",
    "fix-deps": "expo install --fix",
    "deeplink:ios": "npx uri-scheme open \"beamrnsample://details/42\" --ios",
    "deeplink:android": "npx uri-scheme open \"beamrnsample://details/42\" --android"
  },
  "dependencies": {
    "@beamable/sdk": "1.2.0",
    "beamable-notifications-ios": "file:../../iOS/BeamableNotifications/reactnative",
    "beamable-notifications-android": "file:../../Android/BeamableNotifications/reactnative",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@ungap/structured-clone": "^1.3.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.3",
    "expo-dev-client": "~5.0.4",
    "expo-device": "~7.0.1",
    "expo-linking": "~7.0.3",
    "expo-notifications": "~0.29.11",
    "expo-router": "~4.0.11",
    "expo-splash-screen": "~0.29.13",
    "expo-status-bar": "~2.0.0",
    "fake-indexeddb": "^6.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  }
}
