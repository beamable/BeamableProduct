  "Modules": [
    {
      "Name": "BeamPlatformNotifications",
      "Type": "Runtime",
      "LoadingPhase": "Default",
      "PlatformAllowList": [ "IOS", "Android", "Mac", "Win64", "Linux" ]
    },
    {
      "Name": "BeamPlatformNotificationsEditor",
      "Type": "Editor",
      "LoadingPhase": "PostEngineInit"
    }
  ]
}
