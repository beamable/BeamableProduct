<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

  <application>

    <!-- Firebase Cloud Messaging entry point. Receives push + token-refresh events.
         Harmless when remote is disabled / no google-services.json (never invoked). -->
    <service
        android:name="com.beamable.push.PushFirebaseService"
        android:exported="false">
      <intent-filter>
        <action android:name="com.google.firebase.MESSAGING_EVENT" />
      </intent-filter>
    </service>

    <!-- Fires scheduled local notifications (driven by AlarmManager). -->
    <receiver
        android:name="com.beamable.push.NotificationActionReceiver"
        android:exported="false" />

    <!-- Receive-time handlers (§1.1): apps declare ONE OR MORE handler classes via repeated
         <meta-data> entries in their OWN manifest. Because the manifest merger rejects duplicate
         exact names, use the shared key as a PREFIX:
           <meta-data android:name="com.beamable.push.notification_received_handler"
                      android:value="your.first.HandlerClass" />
           <meta-data android:name="com.beamable.push.notification_received_handler.1"
                      android:value="your.second.HandlerClass" />
         PushManager.resolveHandlers() scans every meta-data with this prefix and instantiates each
         via a no-arg constructor. The library itself declares none. -->

    <!-- Default channel for FCM-displayed notifications when none is specified. -->
    <meta-data
        android:name="com.google.firebase.messaging.default_notification_channel_id"
        android:value="@string/beamable_default_channel" />

  </application>

</manifest>
