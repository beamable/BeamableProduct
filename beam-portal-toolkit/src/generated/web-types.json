                "type": "boolean"
              }
            },
            {
              "name": "single-select",
              "description": "",
              "value": {
                "type": "boolean"
              }
            },
            {
              "name": "value",
              "description": "The currently selected rows when `showSelect` is true.",
              "value": {
                "type": "string"
              }
            },
            {
              "name": "dense",
              "description": "",
              "value": {
                "type": "boolean"
              }
            },
            {
              "name": "fixed-header",
              "description": "Fixes the header row so only the body scrolls when `height` is set.",
              "value": {
                "type": "boolean"
              }
            },
            {
              "name": "height",
