            {
              "name": "color",
              "description": "Fill color. Overrides the color implied by `type`.",
              "value": {
                "type": "string"
              }
            },
            {
              "name": "type",
              "description": "Semantic variant: `success`, `info`, `warning`, or `error`. Sets icon and color automatically.",
              "value": {
                "type": "string"
