        {
          "name": "beam-data-table",
          "description": "A full-featured data table with sorting, pagination, filtering, and row selection.",
          "attributes": [
            {
              "name": "headers",
              "description": "Column definitions. Each item requires a `text` (display label) and `value` (row data key).",
              "value": {
                "type": "array"
              }
            },
            {
              "name": "items",
              "description": "Array of row data objects. Each object's keys should match the `value` fields in `headers`.",
              "value": {
                "type": "array"
              }
            },
            {
              "name": "items-per-page",
              "description": "Number of rows shown per page. Set to `-1` to show all rows. Defaults to `10`.",
              "value": {
                "type": "string"
              }
            },
            {
              "name": "loading",
              "description": "Shows a loading bar above the table.",
              "value": {
                "type": "boolean"
              }
            },
            {
              "name": "search",
              "description": "Filters visible rows to those matching this string.",
              "value": {
                "type": "string"
              }
            },
            {
