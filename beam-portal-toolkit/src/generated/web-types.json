          "attributes": [
            {
              "name": "color",
              "description": "Fill color. Accepts a CSS color or theme color name (e.g. `primary`, `error`).",
              "value": {
                "type": "string"
              }
            },
            {
              "name": "outlined",
              "description": "",
              "value": {
                "type": "boolean"
              }
