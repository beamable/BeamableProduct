{
  "name": "@beamable/portal-toolkit",
  "version": "0.1.3",
  "description": "Beamable Portal Toolkit — utilities and web component types for the Beamable portal plugin system",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "customElements": "custom-elements.json",
  "web-types": "src/generated/web-types.json",
  "repository": {
    "type": "git",
    "url": "https://github.com/beamable/BeamableProduct",
    "directory": "beam-portal-toolkit"
  },
  "author": "Beamable",
  "license": "MIT",
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=22.14.0"
  },
  "files": [
    "dist",
    "custom-elements.json",
    "src/generated"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "sync-components": "node scripts/sync-components.mjs",
    "prepublishOnly": "pnpm sync-components --no-copy && pnpm build"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/types/vite.d.ts",
      "require": "./dist/vite.cjs",
      "import": "./dist/vite.mjs"
    },
    "./rollup": {
      "types": "./dist/types/rollup.d.ts",
      "require": "./dist/rollup.cjs",
      "import": "./dist/rollup.mjs"
    },
    "./svelte": {
      "types": "./dist/types/svelte-elements.d.ts"
    },
    "./react-elements": {
      "types": "./dist/types/react-elements.d.ts"
    },
    "./react": {
      "types": "./dist/types/react.d.ts",
      "require": "./dist/react.cjs",
      "import": "./dist/react.mjs"
    },
    "./custom-elements.json": "./custom-elements.json",
    "./web-types.json": "./src/generated/web-types.json"
  },
  "peerDependencies": {
    "@beamable/sdk": "1.1.1",
    "svelte": ">=4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@beamable/sdk": "1.1.1",
    "svelte": "^5.0.0",
    "tsdown": "^0.16.5",
    "typescript": "^5.8.3"
  }
}
